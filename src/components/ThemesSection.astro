---
import BaseSection from '../ui/BaseSection.astro';
import LinkCard from '../components/LinkCard.astro';

const { class: className, title, 'card-list': cardList, ...attrs } = Astro.props;

const validСardList = Array.isArray(cardList) ? cardList : [];

const classes = ['themes-section', className];
---

{
  validСardList.length > 0 && (
    <BaseSection
      title={title}
      class:list={classes}
      {...attrs}
    >
      <div class="themes-section__cards">
        {validСardList.map(card => (
          <LinkCard
            class="themes-section__card"
            link-url={card.linkUrl}
            title={card.title}
            caption-text={card.captionText}
            theme="light"
            border="all"
            arrow-theme="light"
          />
        ))}
      </div>
    </BaseSection>
  )
}

<style lang="scss" is:global>
  .themes-section {
    &__cards {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: rem(138);
      gap: rem(24);
    }

    &__card {
      &:nth-child(3n + 1) {
        grid-row: span 2;

        &:last-child,
        &:nth-last-child(2) {
          grid-row: span 1;
        }
      }
    }
  }
</style>
