<section class="ui-kit-section">
  <div class="ui-kit-section__container">
    <h1 class="ui-kit-section__title">UI-kit</h1>

    <h2 class="ui-kit-section__subtitle">Типографика</h2>

    <div class="ui-kit-section__typography">
      <h1>Заголовок H1</h1>
