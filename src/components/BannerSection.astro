---
import BaseButton from '../ui/BaseButton.astro';
import LinkCard from '../components/LinkCard.astro';

const {
  class: className,
  title,
  text,
  button,
  'image-url': imageUrl,
  'card-list': cardList,
  height = 'md',
  divider = false,
  mb,
  ...attrs
} = Astro.props;

const validСardList = Array.isArray(cardList) ? cardList : [];

const classes = [
  'banner-section',
  validСardList.length > 0 ? 'banner-section_cards' : '',
  `banner-section_height_${height}`,
  divider ? 'banner-section_divider' : '',
  mb ? `banner-section_mb_${mb}` : '',
  className,
];
---

<section
  class:list={classes}
  {...attrs}
>
  <div class="banner-section__container">
    <img
      class="banner-section__background-image"
      src={imageUrl}
      alt="фоновое изображение"
      loading="lazy"
    />
    <div class="banner-section__content">
      {
        validСardList.length > 0 ? (
          <Fragment>
            <div class="banner-section__info">
              {title && <h2 class="banner-section__title">{title}</h2>}
              {text && (
                <div
                  set:html={text}
                  class="banner-section__text"
                />
              )}
              {button?.text && button?.linkUrl && (
                <BaseButton
                  class="banner-section__button"
                  text={button.text}
                  href={button.linkUrl}
                  theme="gray-0"
                />
              )}
            </div>
            <div class="banner-section__cards">
              {validСardList.map(card => (
                <LinkCard
                  class="banner-section__card"
                  link-url={card.linkUrl}
                  title={card.title}
                  theme="secondary"
                  shadow={true}
                  border="top"
                  paddings="lg"
                  arrow-theme="primary"
                />
              ))}
            </div>
          </Fragment>
        ) : (
          <div class="banner-section__info">
            {title && <h1 class="banner-section__title">{title}</h1>}
            {text && (
              <div
                set:html={text}
                class="banner-section__text"
              />
            )}
            {button?.text && button?.linkUrl && (
              <BaseButton
                class="banner-section__button"
                text={button.text}
                href={button.linkUrl}
                theme="gray-0"
              />
            )}
          </div>
        )
      }
    </div>
  </div>
</section>

<style lang="scss" is:global>
  .banner-section {
    $element: &;

    &_height_full {
      display: flex;
      flex-direction: column;
    }

    &__container {
      position: relative;
      display: flex;
      align-items: center;
      width: 100%;
      max-width: 1920px;
      margin-right: auto;
      margin-left: auto;

      #{$element}_height_sm & {
        min-height: rem(658);
      }

      #{$element}_height_md & {
        min-height: rem(728);
      }

      #{$element}_height_full & {
        flex-grow: 1;
        flex-shrink: 0;
        padding-top: var(--header-height);
        padding-bottom: rem(70);
      }

      #{$element}_divider & {
        border-bottom: rem(3) solid $secondary;
      }

      #{$element}_mb_md & {
        margin-bottom: rem(96);
      }
    }

    &__background-image {
      position: absolute;
      top: 0;
      left: 0;
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    &__content {
      @include base-container;

      position: relative;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      padding-top: rem(48);
      padding-bottom: rem(48);
      gap: rem(50);
    }

    &__info {
      max-width: rem(642);
      color: $gray-0;

      #{$element}_cards & {
        max-width: rem(526);
        padding-bottom: rem(74);
      }
    }

    &__title {
      margin: 0;
    }

    &__text {
      @include body-18-demi;

      margin-top: rem(24);

      #{$element}_cards & {
        margin-top: rem(32);
        font-weight: 400;
      }
    }

    &__button {
      display: inline-block;
      margin-top: rem(24);

      #{$element}_cards & {
        margin-top: rem(12);
      }
    }

    &__cards {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: rem(240) rem(240);
      gap: rem(24);
      flex-shrink: 0;
      width: rem(552);
    }
  }
</style>
