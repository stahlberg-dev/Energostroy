---
import BaseSection from '../ui/BaseSection.astro';
import BaseButton from '../ui/BaseButton.astro';
import LinkCard from '../components/LinkCard.astro';

const {
  class: className,
  title,
  'controls-text': controlsText,
  'card-list': cardList,
  ...attrs
} = Astro.props;

const validСardList = Array.isArray(cardList) ? cardList : [];

const classes = ['card-slider-section', 'js-card-slider-section', className];
---

{
  validСardList.length > 0 && (
    <BaseSection
      class:list={classes}
      {...attrs}
    >
      <div class="card-slider-section__header">
        <h2 class="card-slider-section__title">{title}</h2>

        <div class="card-slider-section__controls-wrapper">
          {controlsText && <div class="card-slider-section__controls-text">{controlsText}</div>}

          <div class="card-slider-section__controls">
            <BaseButton
              class="card-slider-section__prev-button js-card-slider-prev"
              theme="transparent-light"
              size="sm"
              right-icon="right-arrow"
            />
            <BaseButton
              class="card-slider-section__next-button js-card-slider-next"
              theme="transparent-light"
              size="sm"
              right-icon="right-arrow"
            />
          </div>
        </div>
      </div>

      <div class="card-slider-section__slider swiper js-card-slider">
        <div class="card-slider-section__slider-wrapper swiper-wrapper">
          {validСardList.map(card => (
            <div class="card-slider-section__slide swiper-slide">
              <LinkCard
                class="card-slider-section__card"
                link-url={card.linkUrl}
                title={card.title}
                caption-text={card.captionText}
                caption-theme="date"
                shadow={true}
                border="top"
                paddings="sm"
                background="gradient"
              />
            </div>
          ))}
        </div>
      </div>
    </BaseSection>
  )
}

<script>
  import { Swiper } from 'swiper';
  import { FreeMode, Navigation } from 'swiper/modules';

  function cardSlider() {
    const cardSliderSections = document.querySelectorAll('.js-card-slider-section');

    cardSliderSections.forEach(cardSliderSection => {
      const sliderElement = cardSliderSection.querySelector('.js-card-slider');

      if (!sliderElement) {
        return;
      }

      const prevButton = cardSliderSection.querySelector('.js-card-slider-prev');
      const nextButton = cardSliderSection.querySelector('.js-card-slider-next');

      if (!prevButton || !nextButton) {
        return;
      }

      new Swiper(sliderElement, {
        modules: [Navigation, FreeMode],
        observer: true,
        observeParents: true,
        observeSlideChildren: true,
        slidesPerView: 3,
        watchOverflow: true,
        speed: 500,
        grabCursor: true,
        freeMode: {
          enabled: true,
          sticky: true,
        },
        navigation: {
          nextEl: nextButton,
          prevEl: prevButton,
        },
      });
    });
  }

  cardSlider();
</script>

<style lang="scss" is:global>
  .card-slider-section {
    &__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: rem(32);
      gap: rem(32);
    }

    &__title {
      @include h2;

      margin: 0;
    }

    &__controls-wrapper {
      display: flex;
      flex-direction: flex-end;
      flex-shrink: 0;
      align-items: center;
      gap: rem(10);
    }

    &__controls-text {
      @include body-18;
    }

    &__controls {
      display: flex;
      flex-direction: flex-end;
      flex-shrink: 0;
      align-items: center;
      gap: rem(16);
    }

    &__prev-button,
    &__next-button {
      flex-shrink: 0;
    }

    &__prev-button {
      transform: rotate(180deg);
    }

    &__slider {
      height: rem(228);
      margin: 0 rem(-12) rem(-16);
    }

    &__slide {
      padding: 0 rem(12) rem(16);
    }

    &__card {
      height: 100%;
    }
  }
</style>
