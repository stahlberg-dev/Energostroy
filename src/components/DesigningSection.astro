---
import { BASE } from '../scripts/helpers/constants.js';
import ArrowButton from '../ui/ArrowButton.astro';

const {
  class: className,
  ...attrs
} = Astro.props;

const classes = ['designing-section', className];

const accordionList = [
  {
    title: 'Инженерные изыскания',
    text: `
      Создание цифрового двойника местности. Этот этап является
      критическим для обеспечения механической безопасности
      зданий и сооружений. За последние 20 лет под руководством
      наших лидеров были проведены исследования на территориях
      со сложнейшей геологией: от карстовых полостей
      и плывунов до зон с высокой сейсмической активностью.
    `,
    modalName: 'engineering-survey',
  },
  {
    title: 'Проектирование: Интеллектуальное моделирование объектов',
    text: `
      Это не просто чертежи, а создание информационной модели,
      которая живет на протяжении всего срока эксплуатации здания.
      Опыт позволяет нам предвидеть узкие места в проекте еще на стадии эскиза,
      оптимизируя металлоемкость и энергоэффективность.
    `,
    modalName: 'object-modeling',
  },
  {
    title: 'Градостроительная документация и экспертиза',
    text: `
      Юридическая чистота и градостроительная эффективность
      проекта — результат 20-летней практики взаимодействия
      с государственными структурами и экспертными советами.
    `,
    modalName: ' town-planning-documentation',
  },
];
---

<section
  id="designing"
  class:list={classes}
  {...attrs}
>
  <div class="designing-section__container">
    <div class="designing-section__title-block">
      <img
        class="designing-section__image"
        src={`${BASE}images/designing-section/designing-image.webp`}
        alt="фото"
      />

      <h2 class="designing-section__title">
        Проектирование и&nbsp;инженерные изыскания
      </h2>
    </div>

    <div class="designing-section__accordion-block js-designing-accordion">
      {accordionList.map((item) => (
        <div class="designing-section__accordion-section js-designing-accordion-section">
          <div
            class="designing-section__accordion-section-title js-designing-accordion-section-title"
            tabindex="0"
          >
            <div class="designing-section__accordion-section-title-text">{item.title}</div>
          </div>

          <div class="designing-section__accordion-section-body-wrapper js-designing-accordion-section-body-wrapper">
            <div class="designing-section__accordion-section-body js-designing-accordion-section-body">
              <p class="designing-section__accordion-section-body-text">{item.text}</p>

              <ArrowButton
                class="designing-section__accordion-section-body--link"
                text="подробнее"
                data-modal-open={item.modalName}
              />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { Accordion } from '../scripts/helpers/commonAccordion.js';
  import { getMediaQueries } from '../scripts/helpers/constants.js';

  function designingAccordion() {
    const mediaQueries = getMediaQueries();

    if (mediaQueries.desktop.matches) {
      return;
    }

    const accordions = document.querySelectorAll('.js-designing-accordion');

    accordions.forEach((accordion) => {
      new Accordion({
        accordionElement: accordion,
        sectionClass: '.js-designing-accordion-section',
        activeSectionClass: '.designing-accordion-section-active',
        sectionTitleClass: '.js-designing-accordion-section-title',
        sectionContentWrapperClass: '.js-designing-accordion-section-body-wrapper',
        sectionContentClass: '.js-designing-accordion-section-body',
        showHideTime: 500,
        onLoadActiveSectionNums: [0],
      }).init();
    });
  }

  designingAccordion();
</script>

<style lang="scss" is:global>
  .designing-section {
    $element: &;

    &__container {
      @include large-container;

      @media #{$tablet} {
        display: flex;
        height: rem(522);
      }

      @media #{$desktop} {
        height: rem(874);
      }
    }

    &__title-block {
      position: relative;
      height: rem(528);

      @media #{$tablet} {
        flex-grow: 1;
        height: 100%;
      }

      &::after {
        content: '';
        display: block;
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(180deg, rgba($dark, 0) 0%, rgba($dark, 0.5) 73%, $dark 100%);
      }
    }

    &__image {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    &__title {
      @include h2;

      position: absolute;
      bottom: rem(32);
      left: rem(16);
      z-index: 1;
      width: calc(100% - rem(32));
      color: $light;

      @media #{$tablet} {
        left: rem(20);
        width: calc(100% - rem(40));
      }

      @media #{$desktop} {
        bottom: rem(46);
      }
    }

    &__accordion-block {
      border-top: 1px solid $light-gray;
      background-color: $dark;

      @media #{$tablet} {
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        border-top: none;
        border-left: 1px solid $light-gray;
        width: calc(50% + #{rem(12)});
      }

      @media #{$desktop} {
        width: calc(50% + #{rem(10)});
      }
    }

    &__accordion-section {
      border-bottom: 1px solid $light-gray;
      padding: 0 rem(16);

      @media #{$tablet} {
        flex-shrink: 0;
        flex-grow: 0;
        padding: 0 rem(20);
        transition: flex-grow $default-transition;
      }

      @media #{$desktop} {
        padding: 0 rem(70) 0 rem(80);
      }

      &:last-child {
        border-bottom: none;
      }

      &.designing-accordion-section-active {
        @media #{$tablet} {
          flex-grow: 2;
        }

        @media #{$desktop} {
          flex-grow: 0;
        }
      }
    }

    &__accordion-section-title {
      padding: rem(32) 0;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
    }

    &__accordion-section-title-text {
      @include h4;

      color: $light;
    }

    &__accordion-section-body-wrapper {
    }

    &__accordion-section-body {
      padding-bottom: rem(32);
    }

    &__accordion-section-body-text {
      @include text1;

      margin-bottom: rem(32);
      color: $light;
      
      @media #{$desktop} {
        max-width: rem(580);
      }
    }
  }
</style>
