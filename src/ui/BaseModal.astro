---
import BaseIcon from '../ui/BaseIcon.astro';

const { 
  class: className,
  name,
  ...attrs
} = Astro.props;

const classes = [
  'base-modal',
  className,
];
---

<div
  class:list={classes}
  data-modal={name}
  {...attrs}
>
  <div class="base-modal__container">
    <div class="base-modal__wrapper">
      <button
        class="base-modal__close-button"
        type="button"
        data-modal-close={name}
      >
        <BaseIcon
          class="base-modal__close-button-icon"
          name="close"
        />
      </button>
      <slot />
    </div>
  </div>
</div>

<script>
  import { Popup } from '../scripts/helpers/commonPopup.js';

  function baseModalInit(
    modalAttributeName,
    invokerAttributeName,
    closerAttributeName,
    modalAnimationTime
  ) {
    const modals = document.querySelectorAll(`[${modalAttributeName}]`);

    if (!modals.length) {
      return;
    }

    const modalHandler = new Popup({
      animationTime: modalAnimationTime,
    });

    function resetForms(modalElement) {
      const modalForms = modalElement?.querySelectorAll('form') ?? [];

      setTimeout(() => {
        modalForms.forEach(modalForm => {
          modalForm.reset();
        });
      }, modalAnimationTime);
    }

    modals.forEach(modal => {
      const modalName = modal.getAttribute(modalAttributeName);

      if (!modalName) {
        return;
      }

      const invokers = document.querySelectorAll(`[${invokerAttributeName}="${modalName}"]`);
      const closers = document.querySelectorAll(`[${closerAttributeName}="${modalName}"]`);

      invokers.forEach(invoker => {
        invoker.addEventListener('click', () => {
          modalHandler.open(modal);
        });
      });

      closers.forEach(closer => {
        closer.addEventListener('click', () => {
          modalHandler.close(modal, () => resetForms(modal));
        });
      });

      modal.addEventListener('click', event => {
        if (event.target === modal) {
          modalHandler.close(modal, () => resetForms(modal));
        }
      });

      modal.addEventListener('open-modal', () => {
        modalHandler.open(modal);
      });

      modal.addEventListener('close-modal', () => {
        modalHandler.close(modal, () => resetForms(modal));
      });
    });

    document.addEventListener('keydown', event => {
      if (event.key !== 'Escape') {
        return;
      }

      modals.forEach(modal => {
        modalHandler.close(modal, () => resetForms(modal));
      });
    });
  }

  baseModalInit('data-modal', 'data-modal-open', 'data-modal-close', 300);
</script>

<style lang="scss" is:global>
  .base-modal {
    $element: &;

    position: fixed;
    top: 0;
    left: 0;
    z-index: 100;
    width: 100vw;
    height: 100vh;
    background: linear-gradient(180deg, rgba($dark, 0) 0%, rgba($dark, 0.5) 73%, $dark 100%);
    opacity: 0;
    overflow-y: scroll;
    pointer-events: none;
    transition: opacity 0.3s ease 0.15s;

    &.popup-active {
      opacity: 1;
      pointer-events: auto;
      transition: opacity $default-transition;
    }

    &__container {
      position: absolute;
      top: 0;
      right: 0;
      transform: translateX(105%);
      height: 100%;
      width: 100%;
      background-color: $dark-40;
      backdrop-filter: blur(32px);
      transition: transform $default-transition;

      @media #{$tablet} {
        width: min-content;
      }

      .popup-active & {
        transform: translateX(0);
        transition: transform 0.3s ease 0.15s;
      }
    }

    &__wrapper {
      height: 100%;
      overflow-y: auto;
      margin-right: rem(8);

      @media #{$tablet} {
        width: min-content;
        margin-right: rem(10);
      }

      &::-webkit-scrollbar {
        width: rem(6);
        background-color: transparent;
      }

      &::-webkit-scrollbar-track {
        background: linear-gradient(180deg, rgba($dark, 0) 0%, rgba($dark, 0.5) 73%, $dark 100%);
        box-shadow: 0 rem(2) rem(4) 0 rgba($light, 0.2) inset;
      }

      &::-webkit-scrollbar-thumb {
        border-radius: 0;
        background-color: $light;
      }
    }

    &__close-button {
      @include resetbtn;

      position: absolute;
      top: rem(32);
      right: rem(16);
      z-index: 10;
      width: rem(60);
      height: rem(60);
      color: $light;
      transition: color $default-transition;

      @media #{$tablet} {
        top: rem(32);
        right: rem(20);
      }

      @media #{$desktop} {
        top: rem(24);
        right: rem(20);
      }

      @media #{$is-hover} {
        &:hover {
          color: $primary;
        }
      }

      &:active,
      &:focus-visible {
        color: $primary;
      }
    }

    &__close-button-icon {
      display: block;
      width: 100%;
      height: 100%;
    }
  }
</style>
